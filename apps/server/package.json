{
	"name": "try-catch-server",
	"version": "1.0.0",
	"description": "Backend server for TryCatch",
	"main": "dist/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsup",
		"start": "node -e \"process.env.NODE_ENV='production'; require('./dist/index.js');\"",
		"db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
		"db:migrate": "tsx src/migrate.ts",
		"db:studio": "drizzle-kit studio --config ./drizzle.config.ts",
		"lint": "eslint src --ext .ts",
		"format": "prettier --write \"src/**/*.ts\"",
		"type-check": "tsc --noEmit"
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@try-catch/shared-types": "workspace:*",
		"chalk": "^5.6.2",
		"date-fns": "^4.1.0",
		"dotenv": "^16.3.1",
		"drizzle-orm": "^0.44.2",
		"enquirer": "^2.4.1",
		"express": "^4.18.2",
		"pg": "^8.11.3",
		"serialport": "^13.0.0",
		"socket.io": "^4.7.2",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/node": "^20.10.6",
		"@types/pg": "^8.10.9",
		"@typescript-eslint/eslint-plugin": "^6.17.0",
		"@typescript-eslint/parser": "^6.17.0",
		"drizzle-kit": "^0.31.1",
		"eslint": "^8.56.0",
		"prettier": "^3.1.1",
		"tsup": "^8.5.1",
		"tsx": "^4.7.0",
		"typescript": "^5.3.3"
	}
}
